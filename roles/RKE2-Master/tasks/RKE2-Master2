- name: Download kubectl binary
  get_url:
    url: "https://dl.k8s.io/release/{{ lookup('url', 'https://dl.k8s.io/release/stable.txt') }}/bin/linux/amd64/kubectl"
    dest: /tmp/kubectl
    mode: '0755'

- name: Download kubectl checksum
  get_url:
    url: "https://dl.k8s.io/release/{{ lookup('url', 'https://dl.k8s.io/release/stable.txt') }}/bin/linux/amd64/kubectl.sha256"
    dest: /tmp/kubectl.sha256

- name: Verify kubectl checksum
  shell: "echo \"$(cat /tmp/kubectl.sha256)  /tmp/kubectl\" | sha256sum --check"
  args:
    executable: /bin/bash

- name: Install kubectl
  command: "install -o root -g root -m 0755 /tmp/kubectl /usr/local/bin/kubectl"

- name: Verify kubectl installation
  command: kubectl version --client
  register: kubectl_version

- debug:
    var: kubectl_version.stdout

#Rke2 Binary
- name: Install required packages
  apt:
    name:
      - curl
      - vim
      - wget
    state: present
    update_cache: yes

- name: Download RKE2 install script
  get_url:
    url: "{{ rke2_install_url }}"
    dest: /tmp/install.sh
    mode: '0755'

- name: Make RKE2 script executable
  file:
    path: /tmp/install.sh
    mode: '0755'

#- name: Install RKE2 server (default channel)
#  command: /tmp/install.sh
#  args:
#    creates: /usr/local/bin/rke2
#  environment:
#    INSTALL_RKE2_TYPE: server

- name: Install RKE2 server (specific version v1.32.10+rke2r1)
  command: /tmp/install.sh
  args:
    creates: /usr/local/bin/rke2
  environment:
    INSTALL_RKE2_TYPE: server
    INSTALL_RKE2_CHANNEL: "{{ rke2_version }}"
  become: yes    


- name: Create RKE2 config directory
  file:
    path: /etc/rancher/rke2
    state: directory
    mode: '0755'

#- name: Calculate master IP dynamically
#  set_fact:
#    calculated_master_ip: "{{ ansible_host.split('.')[:3] | join('.') }}.{{ (ansible_host.split('.')[-1] | int) - 1 }}"
#  run_once: true      

- name: Deploy RKE2 server config
  template:
    src: config.yaml2.j2
    dest: /etc/rancher/rke2/config.yaml
    mode: '0644'
  become: yes     

#- name: Find inventory group containing calculated master IP
#  set_fact:
#    master_group: "{{ item }}"
#  with_items: "{{ groups.keys() }}"
#  when: calculated_master_ip in groups[item]
#  run_once: true

- name: Read token from calculated master
  ansible.builtin.slurp:
    src: /var/lib/rancher/rke2/server/node-token
  delegate_to: "{{ master_ip }}"
  vars:
    ansible_user: "{{ hostvars[inventory_hostname].ansible_user }}"
    ansible_port: "{{ hostvars[inventory_hostname].ansible_port }}"
    ansible_ssh_private_key_file: "{{ hostvars[inventory_hostname].ansible_ssh_private_key_file }}"
    ansible_ssh_common_args: "-o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null"
  run_once: true
  register: local_token

- name: Replace token in remote config
  ansible.builtin.lineinfile:
    path: /etc/rancher/rke2/config.yaml
    regexp: '^token:'
    line: "token: {{ local_token.content | b64decode }}"
  become: yes

- name: Add RKE2 bin and KUBECONFIG to bashrc
  lineinfile:
    path: "/home/{{ ansible_user }}/.bashrc"
    line: "{{ item }}"
    create: yes
  loop:
    - 'export PATH=$PATH:/var/lib/rancher/rke2/bin'
    - 'export KUBECONFIG=/etc/rancher/rke2/rke2.yaml'
  become: no    

- name: Enable and start RKE2 server
  systemd:
    name: rke2-server
    enabled: yes
    state: started
    daemon_reload: yes
  become: yes    

- name: Run kubectl with RKE2 config
  shell: "kubectl get nodes"
  environment:
    PATH: "{{ ansible_env.PATH }}:/var/lib/rancher/rke2/bin"
    KUBECONFIG: /etc/rancher/rke2/rke2.yaml

- name: Verify nodes with kubectl
  shell: kubectl get nodes
  register: kubectl_nodes
  args:
    executable: /bin/bash
  environment:
    PATH: "{{ ansible_env.PATH }}:/var/lib/rancher/rke2/bin"
    KUBECONFIG: /etc/rancher/rke2/rke2.yaml

- name: Show kubectl nodes output
  debug:
    var: kubectl_nodes.stdout

- name: Verify pods across all namespaces
  shell: kubectl get pods -A
  register: kubectl_pods
  args:
    executable: /bin/bash
  environment:
    PATH: "{{ ansible_env.PATH }}:/var/lib/rancher/rke2/bin"
    KUBECONFIG: /etc/rancher/rke2/rke2.yaml    

- debug:
    var: kubectl_pods.stdout

# ------------------------------------------------
# Get node names + IPs from master
# ------------------------------------------------
- name: Get node names and IPs from master
  command: >
    kubectl get nodes
    -o jsonpath='{range .items[*]}{.metadata.name} {.status.addresses[?(@.type=="InternalIP")].address}{"\n"}{end}'
  delegate_to: "{{ master_ip }}"
  vars:
    ansible_user: "{{ hostvars[inventory_hostname].ansible_user }}"
    ansible_port: "{{ hostvars[inventory_hostname].ansible_port }}"
    ansible_ssh_private_key_file: "{{ hostvars[inventory_hostname].ansible_ssh_private_key_file }}"
    ansible_ssh_common_args: "-o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null"
  run_once: true    
  register: node_list_raw
  changed_when: false
  environment:
    KUBECONFIG: /etc/rancher/rke2/rke2.yaml


# ------------------------------------------------
# Convert output into structured list
# ------------------------------------------------
- name: Convert node list to structured data
  set_fact:
    cluster_nodes: >-
      {{
        node_list_raw.stdout_lines
        | map('split', ' ')
        | list
      }}

- name: Add all cluster entries to all cluster nodes
  blockinfile:
    path: /etc/hosts
    marker: "# {mark} ANSIBLE CLUSTER NODES"
    block: |
      {% for node in cluster_nodes %}
      {{ node[1] | trim('\"') }} {{ node[0] | lower }}
      {% endfor %}
  loop: "{{ cluster_nodes | map('last') | list }}"
  loop_control:
    label: "{{ item }}"
  delegate_to: "{{ item }}"
  become: yes
  vars:
    ansible_user: "{{ hostvars[inventory_hostname].ansible_user }}"
    ansible_port: "{{ hostvars[inventory_hostname].ansible_port }}"
    ansible_ssh_private_key_file: "{{ hostvars[inventory_hostname].ansible_ssh_private_key_file }}"
    ansible_ssh_common_args: "-o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null"     
