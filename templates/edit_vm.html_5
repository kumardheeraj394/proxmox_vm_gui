<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Edit VM</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
.console {
    background: #000;
    color: #00ff00;
    padding: 15px;
    height: 400px;
    overflow-y: auto;
    font-family: monospace;
    font-size: 13px;
    border-radius: 6px;
    white-space: pre-wrap;
}
</style>
</head>

<body>
<div class="container mt-4">

<h3>Edit VM {{ vm.vmid }}</h3>

{% with messages = get_flashed_messages(with_categories=true) %}
  {% if messages %}
    {% for category, message in messages %}
      <div class="alert alert-{{ category }}">
        {{ message }}
      </div>
    {% endfor %}
  {% endif %}
{% endwith %}

<form method="POST">

<div class="card p-3 mb-3">

  <!-- Basic VM Info -->
  <div class="row mb-3">
    <div class="col-md-3">
      <label class="form-label">VM Name</label>
      <input type="text" name="vmname" class="form-control"
             value="{{ vm.vmname }}" required>
    </div>

    <div class="col-md-3">
      <label class="form-label">IP Address</label>
      <input type="text" name="ipaddr" class="form-control"
             value="{{ vm.ipaddr }}" required>
    </div>

    <div class="col-md-3">
      <label class="form-label">SSH Port</label>
      <input type="number" name="ssh_port" class="form-control"
             value="{{ vm.ssh_port }}" required>
    </div>

    <div class="col-md-3">
      <label class="form-label">Target Node</label>
      <input type="text" name="target_node" class="form-control"
             value="{{ vm.target_node }}" required>
    </div>
  </div>

  <!-- Disk Configuration -->
  <div class="row mb-3">
    <div class="col-md-3">
      <label class="form-label">Primary Disk (GB)</label>
      <input type="number"
             name="disksize"
             class="form-control"
             value="{{ vm.disksize if vm.disksize else 20 }}"
             min="1"
             required>
    </div>

    <div class="col-md-3">
      <label class="form-label">Extra Disk (GB)</label>
      <input type="number"
             name="extra_disksize"
             class="form-control"
             value="{{ vm.extra_disksize if vm.extra_disksize else 0 }}"
             min="0">
    </div>
  </div>

  <!-- Ansible Roles -->
  <div class="mb-3">
    <label class="form-label">Select Ansible Roles</label>
    <select name="ansible_roles" class="form-select" multiple size="5">
      {% for role in roles %}
        <option value="{{ role }}"
          {% if role in vm.ansible_roles %}selected{% endif %}>
          {{ role }}
        </option>
      {% endfor %}
    </select>
    <small class="text-muted">
      Hold CTRL (or CMD on Mac) to select multiple roles
    </small>
  </div>

</div>

<button type="submit" class="btn btn-primary">
  Update & Run
</button>

<a href="{{ url_for('dashboard') }}" class="btn btn-secondary">
  Back
</a>

</form>

<hr>

<h5>Ansible Console</h5>

<div class="mb-2">
  <button onclick="refreshLog()" class="btn btn-dark btn-sm">
    Refresh Log
  </button>
</div>

<pre id="console" class="console">
Waiting for logs...
</pre>

</div>

<script>

function refreshLog() {
    fetch("/ansible_log/{{ vm.vmid }}")
        .then(response => response.text())
        .then(data => {
            let consoleDiv = document.getElementById("console");

            if (data.trim() === "") {
                consoleDiv.textContent = "No logs yet...";
            } else {
                consoleDiv.textContent = data;
                consoleDiv.scrollTop = consoleDiv.scrollHeight;
            }
        })
        .catch(err => {
            document.getElementById("console").textContent =
                "Error loading log.";
        });
}

setInterval(refreshLog, 3000);
refreshLog();

</script>

</body>
</html>
