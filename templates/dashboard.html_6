<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>StackFlow Virtualization Manager (SVM)</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
body { font-size: 13px; }

.badge-ONLINE  { background-color: #198754; }
.badge-OFFLINE { background-color: #dc3545; }
.badge-UNKNOWN { background-color: #6c757d; }

table td, table th {
    vertical-align: middle !important;
}
</style>
</head>

<body>
<div class="container-fluid mt-3">

<!-- ================= TOP BAR ================= -->
<div class="d-flex justify-content-between align-items-center mb-3">
    <h4>StackFlow Virtualization Manager (SVM)</h4>
    <div>
        <span class="me-3">
            Logged in as <strong>{{ username }}</strong> ({{ role }})
        </span>

        <a href="{{ url_for('change_password') }}" class="btn btn-outline-primary btn-sm me-2">
            Change Password
        </a>

        <a href="{{ url_for('logout') }}" class="btn btn-outline-danger btn-sm">
            Logout
        </a>
    </div>
</div>

<!-- ================= FLASH MESSAGES ================= -->
{% with messages = get_flashed_messages(with_categories=true) %}
{% if messages %}
    {% for category, message in messages %}
        <div class="alert alert-{{ category }} alert-dismissible fade show">
            {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endfor %}
{% endif %}
{% endwith %}

<!-- ================= ACTION BUTTONS ================= -->
<div class="mb-3">
    <a href="{{ url_for('vm_form') }}" class="btn btn-primary btn-sm">
        Create VM
    </a>

    {% if role == 'admin' %}
    <button class="btn btn-warning btn-sm ms-2"
            data-bs-toggle="modal"
            data-bs-target="#addVmModal">
        Add VM Record
    </button>
    {% endif %}

    <a href="{{ url_for('download_inventory') }}" class="btn btn-success btn-sm ms-2">
        Download Inventory
    </a>
</div>

<div class="row">

<!-- ================= VM TABLE ================= -->
<div class="col-md-8">
    <div class="card mb-3">

        <div class="card-header d-flex justify-content-between align-items-center">
            <span>VM Status</span>

            <form method="get" class="d-flex align-items-center">
                <label class="me-2 small text-muted">Rows:</label>
                <select name="per_page"
                        class="form-select form-select-sm"
                        style="width:auto;"
                        onchange="this.form.submit()">
                    {% for n in [10,20,50,100] %}
                    <option value="{{ n }}"
                        {% if per_page == n %}selected{% endif %}>
                        {{ n }}
                    </option>
                    {% endfor %}
                </select>
            </form>
        </div>

        <div class="card-body p-0">
            <table class="table table-striped table-hover mb-0" id="vmTable">
                <thead class="table-light">
                    <tr>
                        <th>VM ID</th>
                        <th>VM Name</th>
                        <th>IP</th>
                        <th>Target Node</th>
                        <th>SSH Port</th>
                        <th>Status</th>
                        <th>Timestamp</th>
                        <th>Created By</th>
                        <th class="text-center" style="width:170px;">Actions</th>
                    </tr>
                    <tr>
                        {% for i in range(8) %}
                        <th>
                            <input type="text"
                                   class="form-control form-control-sm column-filter"
                                   placeholder="Search">
                        </th>
                        {% endfor %}
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                {% for vm in vms %}
                <tr>
                    <td>{{ vm.vmid }}</td>
                    <td>{{ vm.vmname }}</td>
                    <td>{{ vm.ipaddr }}</td>
                    <td>{{ vm.target_node }}</td>
                    <td>{{ vm.ssh_port }}</td>
                    <td>
                        <span class="badge badge-{{ vm.ssh_status|upper }}">
                            {{ vm.ssh_status }}
                        </span>
                    </td>
                    <td>{{ vm.timestamp }}</td>
                    <td>{{ vm.created_by }}</td>
                    <td class="text-center" style="white-space: nowrap;">

                        <a href="{{ url_for('vm_edit.edit_vm', vmid=vm.vmid) }}"
                           class="btn btn-sm btn-primary px-2 py-1">
                           Edit
                        </a>

                        {% if role == 'admin' %}
                        <a href="{{ url_for('delete_vm', vmid=vm.vmid) }}"
                           class="btn btn-sm btn-danger px-2 py-1"
                           onclick="return confirm('Delete VM {{ vm.vmid }}?')">
                           Delete
                        </a>
                        {% endif %}

                    </td>
                </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    <!-- ================= PAGINATION ================= -->
    <nav>
      <ul class="pagination pagination-sm">
        {% for p in range(1, total_pages + 1) %}
        <li class="page-item {% if p == page %}active{% endif %}">
            <a class="page-link"
               href="{{ url_for('dashboard', page=p, per_page=per_page) }}">
               {{ p }}
            </a>
        </li>
        {% endfor %}
      </ul>
    </nav>
</div>

<!-- ================= USERS TABLE ================= -->
{% if role == 'admin' %}
<div class="col-md-4">
    <div class="card mb-3">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span>Users</span>
            <a href="{{ url_for('create_user') }}" class="btn btn-success btn-sm">
                Create User
            </a>
        </div>

        <div class="card-body p-0">
            <table class="table table-bordered table-hover mb-0" id="userTable">
                <thead class="table-light">
                    <tr>
                        <th>Username</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Action</th>
                    </tr>
                    <tr>
                        <th><input type="text" class="form-control form-control-sm column-filter" placeholder="Search"></th>
                        <th><input type="text" class="form-control form-control-sm column-filter" placeholder="Search"></th>
                        <th><input type="text" class="form-control form-control-sm column-filter" placeholder="Search"></th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                {% for user in users %}
                <tr>
                    <td>{{ user[0] }}</td>
                    <td>{{ user[1] }}</td>
                    <td>{{ user[2] }}</td>
                    <td>
                        <a href="{{ url_for('modify_user', username=user[0]) }}"
                           class="btn btn-sm btn-warning">
                           Modify
                        </a>
                    </td>
                </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endif %}

</div>
</div>

<!-- ================= ADD VM MODAL ================= -->
{% if role == 'admin' %}
<div class="modal fade" id="addVmModal" tabindex="-1">
  <div class="modal-dialog">
    <form method="POST" action="{{ url_for('add_vm') }}" class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Add VM Record</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>

      <div class="modal-body">
        <div class="mb-2">
          <label class="form-label">VM ID</label>
          <input type="text" name="vmid" class="form-control" required>
        </div>
        <div class="mb-2">
          <label class="form-label">VM Name</label>
          <input type="text" name="vmname" class="form-control" required>
        </div>
        <div class="mb-2">
          <label class="form-label">IP Address</label>
          <input type="text" name="ipaddr" class="form-control" required>
        </div>
        <div class="mb-2">
          <label class="form-label">Target Node</label>
          <input type="text" name="target_node" class="form-control" required>
        </div>
        <div class="mb-2">
          <label class="form-label">SSH Port</label>
          <input type="number" name="ssh_port" value="22" class="form-control" required>
        </div>
      </div>

      <div class="modal-footer">
        <button type="submit" class="btn btn-warning btn-sm">Add VM</button>
        <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
      </div>
    </form>
  </div>
</div>
{% endif %}

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

<!-- ================= MULTI COLUMN SEARCH ================= -->
<script>
document.addEventListener("DOMContentLoaded", function() {

    document.querySelectorAll("table").forEach(function(table) {

        const filters = table.querySelectorAll(".column-filter");

        filters.forEach(function(input) {

            input.addEventListener("keyup", function() {

                const rows = table.querySelectorAll("tbody tr");

                rows.forEach(function(row) {

                    let show = true;

                    filters.forEach(function(f, index) {
                        if (!f.value) return;

                        const cell = row.cells[index];
                        if (!cell) return;

                        if (!cell.textContent.toLowerCase().includes(f.value.toLowerCase())) {
                            show = false;
                        }
                    });

                    row.style.display = show ? "" : "none";
                });

            });

        });

    });

});
</script>

</body>
</html>

